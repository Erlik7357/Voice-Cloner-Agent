# Backend Configuration
VOICE_CLONER_GPU=0              # Set to 1 to enable CUDA GPU acceleration
VOICE_CLONER_PRELOAD=1          # Set to 0 to skip model pre-loading on server start
VOICE_CLONER_DEBUG=0            # Set to 1 to enable Flask debug mode

# Dashboard Configuration
VITE_API_BASE_URL=http://localhost:5000   # Backend API URL for the dashboard
